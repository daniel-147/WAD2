{{> head}}
{{> header}}

{{> navigation}}

<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-10">

      <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-4">
        <div>
          <h1 class="h3 mb-1">{{course.title}}</h1>
          <div class="text-muted">
            {{#course.duration}}
              <span class="me-2">Duration: <strong>{{course.duration}}</strong></span>
            {{/course.duration}}
            <span class="me-2">Level: <strong>{{course.level}}</strong></span>
            <span class="me-2">Type: <strong>{{course.type}}</strong></span>
            {{#course.allowDropIn}}
              <span class="badge text-bg-success">Drop-in available</span>
            {{/course.allowDropIn}}
          </div>
        </div>

        {{#isOrganiser}}
          <div class="text-end">
            <a class="btn btn-outline-secondary" href="/organiser/update-course/{{course.id}}">
              Update Course
            </a>
          </div>
        {{/isOrganiser}}
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <p class="mb-2">{{course.description}}</p>
          <div class="small text-muted">
            Dates: <strong>{{course.startDate}}</strong> – <strong>{{course.endDate}}</strong>
          </div>
        </div>
      </div>

      <section class="mb-4">
        <h2 class="h5 mb-3">Book the full course</h2>

        <div class="card shadow-sm">
          <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span class="text-muted">Reserve a place for the whole course.</span>
            <form
                  method="post"
                  action="/courses-page/{{course.id}}/book"
                  class="m-0"
                >
                  <button
                    type="submit"
                    class="btn btn-primary btn-sm"
                  >
                    Book Course
                  </button>
                </form>
          </div>

          {{#courseBooked}}
            <div class="card-footer">
              <div class="alert alert-success mb-0 py-2 px-3 auto-hide" role="alert">
                You are enrolled in this course!
              </div>
            </div>
          {{/courseBooked}}
        </div>
      </section>

      <section class="mb-4">
        <h2 class="h5 mb-3">Sessions</h2>

        {{#sessions}}
          {{! table shown below outside the loop; keep loop for rows only }}
        {{/sessions}}

        <div class="card shadow-sm">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Start</th>
                    <th>End</th>
                    <th>Description</th>
                    <th>Location</th>
                    <th class="text-end">Price</th>
                    <th class="text-end">Capacity</th>
                    <th class="text-end">Booked</th>
                    <th class="text-end">Remaining</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {{#sessions}}
                    <tr>
                      <td>{{start}}</td>
                      <td>{{end}}</td>
                      <td>{{description}}</td>
                      <td>{{location}}</td>
                      <td class="text-end">{{price}}</td>
                      <td class="text-end">{{capacity}}</td>
                      <td class="text-end">{{booked}}</td>
                      <td class="text-end">{{remaining}}</td>
                      <td class="text-end">
                        {{#course.allowDropIn}}
                          <form
                  method="post"
                  action="/sessions/{{id}}/book"
                  class="m-0"
                >
                  <button
                    type="submit"
                    class="btn btn-primary btn-sm"
                  >
                    Book Session
                  </button>
                </form>
                          {{#justBooked}}
                            <div class="small text-success mt-1 auto-hide">You have booked this session!</div>
                          {{/justBooked}}
                        {{/course.allowDropIn}}

                        {{#isOrganiser}}
                          <div class="mt-2">
                            <a class="btn btn-sm btn-outline-secondary" href="/organiser/sessions/{{id}}/participants">
                              View Participants
                            </a>
                          </div>
                        {{/isOrganiser}}
                      </td>
                    </tr>
                  {{/sessions}}
                </tbody>
              </table>
            </div>
          </div>

          {{^sessions}}
            <div class="card-body">
              <div class="alert alert-info mb-0" role="alert">
                No sessions available for this course.
              </div>
            </div>
          {{/sessions}}
        </div>
      </section>

    </div>
  </div>
</main>

<script>
  setTimeout(() => {
    document
      .querySelectorAll(".auto-hide")
      .forEach(el => el.style.display = "none");
  }, 3000);
</script>


{{> footer}}